# =============================================================================
# DataMind .env.example
# Copy to `.env` and fill in. Mock-by-default: leaving values blank keeps the
# system fully functional in offline / demo mode.
# =============================================================================

# --- General ---------------------------------------------------------------
DATAMIND_ENV=development                  # development | staging | production
DATAMIND_LOG_LEVEL=INFO

# --- Backend (FastAPI) -----------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_JWT_SECRET=devsecret-change-me-32chars-min-xxxxxxxxxx
BACKEND_JWT_ALG=HS256
BACKEND_JWT_TTL_SECONDS=86400
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production: include your deployed frontend origin(s), comma-separated, no trailing slashes, e.g.
# BACKEND_CORS_ORIGINS=https://app.example.com,https://www.example.com,http://localhost:3000
# Optional regex so Vercel preview URLs work without listing each deploy (default allows https://*.vercel.app).
# Set to "-" or empty to disable and use BACKEND_CORS_ORIGINS only.
# BACKEND_CORS_ORIGIN_REGEX=https://.*\.vercel\.app
BACKEND_RATE_LIMIT_PER_MINUTE=120
BACKEND_UPLOAD_DIR=./storage_local
BACKEND_MAX_UPLOAD_MB=200

# --- Postgres --------------------------------------------------------------
# Container exposes 5432 internally; host port is 55432 to avoid colliding
# with a system-installed Postgres. Override with POSTGRES_HOST_PORT in compose.
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_HOST_PORT=55432
POSTGRES_DB=datamind
POSTGRES_USER=datamind
POSTGRES_PASSWORD=datamind
DATABASE_URL=postgresql+asyncpg://datamind:datamind@localhost:55432/datamind

# --- Redis (queue + WebSocket pubsub) --------------------------------------
REDIS_HOST_PORT=56379
REDIS_URL=redis://localhost:56379/0

# --- Qdrant (vector DB) ----------------------------------------------------
QDRANT_HOST_PORT=56333
QDRANT_GRPC_HOST_PORT=56334
QDRANT_URL=http://localhost:56333
QDRANT_API_KEY=
QDRANT_COLLECTION=datamind_chunks
QDRANT_VECTOR_SIZE=384

# --- AI Engine -------------------------------------------------------------
AI_ENGINE_URL=http://localhost:8100
AI_ENGINE_PORT=8100
AI_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
AI_HF_CACHE=./hf-cache
AI_LORA_OUTPUT_DIR=./checkpoints

# --- 0G Integration --------------------------------------------------------
# Leave blank to run in deterministic mock mode (default for hackathon demo).
# Set DATAMIND_OG_MOCK=0 + the keys below to publish to Galileo testnet.
# While DATAMIND_OG_MOCK=1 the pipeline simulates 0G + registry: no explorer txs.
# For real on-chain anchoring use either DATAMIND_WEB3_USER_TX=1 + deployed contracts,
# or DATAMIND_OG_MOCK=0 + OG_PRIVATE_KEY + DATASET_REGISTRY_ADDRESS (server-signed).
DATAMIND_OG_MOCK=1
OG_EVM_RPC=https://evmrpc-testnet.0g.ai
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# Hot wallet for server-side storage txs only (never commit). Must hold Galileo testnet gas
# for the flow the indexer uses; fund via https://faucet.0g.ai (see https://build.0g.ai/storage/).
OG_PRIVATE_KEY=
OG_CHAIN_NETWORK=galileo-testnet-16602
OG_CHAIN_ID=16602
# Deployed contract addresses (paste after `forge script Deploy`):
DATASET_REGISTRY_ADDRESS=
DATASET_NFT_ADDRESS=
TRAINING_REGISTRY_ADDRESS=
USAGE_ECONOMY_ADDRESS=
LICENSE_REGISTRY_ADDRESS=

# When 1, after storage the dataset waits in PENDING_CHAIN and the user must
# approve register + mint in their wallet (needs deployed contracts + env addresses).
# Set 0 for pure local demo or server-signed chain (legacy).
DATAMIND_WEB3_USER_TX=1

# Async chain log indexer — polls eth_getLogs and mirrors events to Postgres.
# Requires DATASET_REGISTRY_ADDRESS and OG_EVM_RPC.
DATAMIND_CHAIN_INDEXER=0
DATAMIND_CHAIN_INDEXER_START_BLOCK=0
DATAMIND_CHAIN_INDEXER_POLL_SECONDS=5

# --- Privy (wallet auth) ---------------------------------------------------
# Leave blank to use the bundled mock wallet for demo.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Production with real Privy: set to 1 so clients cannot use privy_token=mock and a forged wallet.
# DATAMIND_PRIVY_REJECT_DEMO_TOKEN=1
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Frontend (Next.js) ----------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE=ws://localhost:8000/ws
# Vercel/Netlify build: set BACKEND_INTERNAL_URL to the same API base as above so
# /api/proxy rewrites work when the browser uses same-origin /api/proxy (recommended).
# BACKEND_INTERNAL_URL=https://api.example.com/api/v1
NEXT_PUBLIC_CHAIN_ID=16602
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/datamind
NEXT_PUBLIC_DOCS_URL=https://docs.0g.ai

# --- Web3 (RainbowKit + wagmi, frontend) -----------------------------------
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_OG_EXPLORER_URL=https://chainscan-galileo.0g.ai
NEXT_PUBLIC_OG_FAUCET_URL=https://faucet.0g.ai
# WalletConnect (Reown) project id — leave blank to keep MetaMask-only demo.
NEXT_PUBLIC_WC_PROJECT_ID=
# Paste deployed addresses below (must match the backend's DATASET_* env vars).
NEXT_PUBLIC_DATASET_REGISTRY=
NEXT_PUBLIC_DATASET_NFT=
NEXT_PUBLIC_TRAINING_REGISTRY=
NEXT_PUBLIC_USAGE_ECONOMY=
NEXT_PUBLIC_LICENSE_REGISTRY=
